{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["openai"],
  "model": "openai/gpt-5.4",
  "default_agent": "plan",
  "autoupdate": true,
  "agent": {
    "plan": {
      "permission": {
        "write": "ask",
        "edit": "ask"
      }
    }
  },
  "lsp": {
    "clojure-lsp": {
      "command": [
        "/opt/homebrew/bin/clojure-lsp"
      ],
      "extensions": [
        ".clj",
        ".cljs",
        ".cljc",
        ".edn"
      ],
      "env": {
        "CLOJURE_LSP_LOG_LEVEL": "info"
      },
      "initialization": {
        "initializationOptions": {
          "project-root-uri-as-project-root?": true,
          "text-document-sync-kind": 2
        }
      }
    }
  },
  "mcp": {
    // https://www.atlassian.com/platform/remote-mcp-server
    // Authenticate via: opencode mcp auth jira
    "jira": {
      "enabled": false,
      "url": "https://mcp.atlassian.com/v1/mcp",
      "type": "remote",
      "oauth": {}
    }
  }
}
